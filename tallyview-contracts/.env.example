# Deployer private key (with or without 0x prefix — both work)
PRIVATE_KEY=

# Tallyview relay service address — granted SYSTEM_ROLE on deploy
RELAY_ADDRESS=

# RPC endpoint for the Tallyview L1 (Subnet-EVM)
# Default: Avalanche Fuji C-Chain (placeholder until L1 is deployed)
TALLYVIEW_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Set after deploy — used by register-test-org.ts and future scripts
AUDIT_LEDGER_ADDRESS=

# Test org address — used by register-test-org.ts
ORG_ADDRESS=
