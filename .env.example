# Tallyview Environment Variables
# Copy to .env.local and fill in values.

# ---------------------------------------------------------------------------
#  Supabase (required)
# ---------------------------------------------------------------------------
# Pooled connection (port 6543) — used at runtime by Prisma Client
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used by Prisma Migrate
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
# Supabase project keys (for auth)
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ---------------------------------------------------------------------------
#  QuickBooks Online Integration
# ---------------------------------------------------------------------------
QBO_CLIENT_ID=your_client_id
QBO_CLIENT_SECRET=your_client_secret
QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback
QBO_ENVIRONMENT=sandbox
QBO_BASE_URL=https://sandbox-quickbooks.api.intuit.com/v3
QBO_REALM_ID=your_sandbox_realm_id
# Shortcut: paste an access token from the Intuit Developer portal to skip OAuth
# QBO_ACCESS_TOKEN=paste_from_portal

# ---------------------------------------------------------------------------
#  Resend (email invitations)
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@tallyview.com

# ---------------------------------------------------------------------------
#  Avalanche Fuji (on-chain relay)
# ---------------------------------------------------------------------------
RELAY_PRIVATE_KEY=0x_your_relay_private_key

# ---------------------------------------------------------------------------
#  OpenAI (990 AI classification)
# ---------------------------------------------------------------------------
# Required for AI-based transaction classification into IRS 990 line items.
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key

# ---------------------------------------------------------------------------
#  Token Encryption (required in production)
# ---------------------------------------------------------------------------
# 32-byte hex key for AES-256-GCM encryption of QBO OAuth tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Without this key, OAuth tokens are stored in plaintext in the database.
TOKEN_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
#  Optional
# ---------------------------------------------------------------------------
# Site password protection (leave blank to disable)
SITE_PASSWORD=
