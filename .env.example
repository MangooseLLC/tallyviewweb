# Tallyview Environment Variables
# All variables are optional for the demo — the app runs standalone with synthetic data.

# Site Password Protection (optional)
# Set this to require a password before accessing the site.
# Leave blank or unset to disable password protection.
SITE_PASSWORD=

# Vercel Postgres (optional - required for waitlist submissions)
# Create a Postgres database in Vercel (Storage tab), then run:
#   vercel env pull .env.local
# to get POSTGRES_URL and other connection vars. Run lib/db/waitlist-schema.sql
# in the Vercel Postgres Query tab to create the waitlist table.
# POSTGRES_URL=postgres://...

# QuickBooks Online Integration
# Get these from https://developer.intuit.com → your app → Development Keys
QBO_CLIENT_ID=your_client_id
QBO_CLIENT_SECRET=your_client_secret
QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback
QBO_ENVIRONMENT=sandbox
QBO_BASE_URL=https://sandbox-quickbooks.api.intuit.com/v3
QBO_REALM_ID=your_sandbox_realm_id

# Shortcut: paste an access token from the Intuit Developer portal to skip OAuth
# QBO_ACCESS_TOKEN=paste_from_portal

# Prisma SQLite
DATABASE_URL="file:./prisma/dev.db"

